{
    "version": 3,
    "configurePresets": [
        {
            "name": "vcpkg",
            "displayName": "vcpkg config",
            "description": "Configure with vcpkg toolchain",
            "binaryDir": "${sourceDir}/build",
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "BUILD_TESTING": "ON",
                "SWIG_PYTHON": "OFF",
                "MOD_AVFORMAT": "ON",
                "MOD_DECKLINK": "OFF",
                "MOD_FREI0R": "OFF",
                "MOD_GDK": "ON",
                "MOD_JACKRACK": "OFF",
                "USE_LV2": "OFF",
                "USE_VST2": "OFF",
                "MOD_KDENLIVE": "ON",
                "MOD_NDI": "OFF",
                "MOD_NORMALIZE": "ON",
                "MOD_OLDFILM": "ON",
                "MOD_OPENCV": "ON",
                "MOD_MOVIT": "OFF",
                "MOD_PLUS": "ON",
                "MOD_PLUSGPL": "OFF",
                "MOD_QT6": "ON",
                "MOD_SOX": "OFF",
                "MOD_GLAXNIMATE_QT6": "OFF",
                "MOD_RESAMPLE": "OFF",
                "MOD_RTAUDIO": "OFF",
                "MOD_RUBBERBAND": "ON",
                "MOD_SDL2": "ON",
                "MOD_SPATIALAUDIO": "OFF",
                "MOD_VIDSTAB": "OFF",
                "MOD_VORBIS": "ON",
                "MOD_XINE": "OFF",
                "MOD_XML": "ON"
            }
        },
        {
            "name": "vcpkg-ninja",
            "inherits": "vcpkg",
            "generator": "Ninja"
        },
        {
            "name": "cc-debug",
            "displayName": "default system compiler (debug)",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "generator": "Ninja",
            "environment": {
                "QT_VERSION": "6.8.3",
                "PKG_CONFIG_PATH": "$env{HOME}/.local/lib/pkgconfig:$env{HOME}/.local/lib64/pkgconfig:$env{HOME}/opt/lib/pkgconfig:$env{HOME}/lib/pkgconfig:/usr/local/lib/pkgconfig:/opt/local/lib/pkgconfig:/usr/lib/pkgconfig:/usr/lib64/pkgconfig:$penv{PKG_CONFIG_PATH}",
                "PATH": "$env{HOME}/Qt/$env{QT_VERSION}/macos/bin:$env{HOME}/opt/bin:/usr/local/bin:/opt/local/bin:$penv{PATH}"
            },
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "$env{HOME}/opt",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_PREFIX_PATH": "$env{HOME}/Qt/$env{QT_VERSION}/macos;$env{HOME}/.local;$env{HOME}/opt;/usr/local;/opt/local",
                "RELOCATABLE": "OFF",
                "MOD_GDK": "OFF",
                "MOD_SDL1": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "clang-format_install",
            "displayName": "clang-format, build, install",
            "configurePreset": "cc-debug",
            "targets": [
                "clang-format",
                "install"
            ]
        }
    ]
}